# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stratix_db
DB_USER=stratix_user
DB_PASSWORD=your_strong_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_with_64_byte_hex_string
REFRESH_TOKEN_SECRET=replace_with_another_64_byte_hex_string
TEMP_TOKEN_SECRET=replace_with_another_64_byte_hex_string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
TEMP_TOKEN_EXPIRES_IN=5m

# ─── Email (Dev: use Mailtrap https://mailtrap.io) ────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM="Stratix BMS <noreply@stratix.com>"

# ─── Company Info ─────────────────────────────────────────────────────────────
COMPANY_NAME=Stratix
COMPANY_ADDRESS=123 Business Avenue, Dhaka, Bangladesh
COMPANY_LOGO_URL=http://localhost:3000/logo.png

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
MAX_PRODUCT_IMAGE_MB=2

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── 2FA ──────────────────────────────────────────────────────────────────────
TOTP_ISSUER=Stratix BMS

# ─── Tax (default, overridable per invoice) ───────────────────────────────────
DEFAULT_TAX_RATE=0

# ─── API Base URL (used in OAuth redirects) ───────────────────────────────────
API_BASE_URL=http://localhost:5000

# ─── OAuth — Google (https://console.cloud.google.com) ───────────────────────
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — Facebook (https://developers.facebook.com) ──────────────────────
# Leave blank to disable Facebook login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── OAuth — LinkedIn (https://www.linkedin.com/developers) ──────────────────
# Leave blank to disable LinkedIn login
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
